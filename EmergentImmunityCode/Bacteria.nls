;; ---- recalculates similarity every tick and updates colour to reflect mimicry progress ----
;; FIX 1: original code calculated similarity into a local variable called 'copy'
;;         but never wrote it back to similarity-to-body
;;         so immune cells were always reading the stale value from spawn time
;; FIX 2: original thresholds were integers (15, 25, 45) applied to a 0-1 score
;;         corrected to fractional thresholds matching the actual similarity range
to bacteria-update-colour
  ;; recalculate and save similarity-to-body every tick
  ;; CRITICAL: immune cells read this value to decide whether to attack or ignore
  set similarity-to-body genome-similarity genome body-genome

  ifelse similarity-to-body < 0.30 [
    set color red      ;; very foreign genome — easy for immune cells to spot
  ] [
    ifelse similarity-to-body < 0.60 [
      set color orange   ;; partial mimicry developing
    ] [
      ifelse similarity-to-body < 0.85 [
        set color yellow   ;; strong mimicry — hard for immune cells to detect
      ] [
        set color pink    ;; near-perfect copy — almost invisible to immunity
      ]
    ]
  ]
end

;; ---- reporters ----

;; report the highest similarity score among all live bacteria
;; tracks how far along mimicry evolution has progressed in the best individual
to-report best-bacteria
  ifelse any? bacteria [
    report max [similarity-to-body] of bacteria
  ] [
    report 0
  ]
end

;; reports how close the best bacterium is to breaching the immune detection threshold
;; 0.0 = best bacterium looks nothing like body-genome
;; 1.0 = best bacterium has reached or passed the threshold — immune cells leave it alone
;; this is what the RED line on the Genome Fitness graph should report
;; when this line hits 1.0 it means bacteria are successfully fooling immune cells
to-report best-bacteria-vs-threshold
  let threshold (lvenchisten-function / 100)
  if threshold = 0 [ report 0 ]
  report min (list 1.0 (best-bacteria / threshold))
end
