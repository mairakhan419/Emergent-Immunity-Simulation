;; ---- BACTERIA EVOLUTION ----
;; fitness = ticks-survived + 2*times-fooled + 10*similarity-to-body
;; rewards bacteria that lived long, successfully fooled immune cells,
;; AND have a genome already close to body-genome
;; bacteria reproduce asexually — one parent, directed mutation only, no recombination
to evolve-bacteria
  ;; select the fittest bacterium as the parent for the next generation
  ;; similarity-to-body * 10 gives directional selection pressure toward body-genome
  ;; even before any immune cells have been fooled yet
  if any? bacteria [
    let fittest max-one-of bacteria [ticks-survived + (times-fooled * 2) + (similarity-to-body * 10)]
    set last-fittest-bacteria-genome [genome] of fittest
  ]

  ;; fallback if no genome was ever recorded
  if last-fittest-bacteria-genome = "" [
    set last-fittest-bacteria-genome randomGenomeFunction
  ]

  ;; save parent genome before wiping the population
  ;; must be saved here or it is lost when ask bacteria [die] runs
  let parent-genome last-fittest-bacteria-genome

  ;; kill the entire current generation
  ask bacteria [ die ]

  ;; spawn next generation using DIRECTED mutation
  ;; each offspring mutates independently so the generation has diversity
  ;; directed mutation steers each character toward the matching body-genome base
  ;; this is what makes bacteria visibly climb toward mimicry on the graph
  create-bacteria min (list initial-bacteria-count max-bacteria) [
    set genome directedMutationFunction parent-genome body-genome (mutation-rate% / 1000)
    set similarity-to-body genome-similarity genome body-genome
