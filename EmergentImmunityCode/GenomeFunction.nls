;; ---- directed mutation function specifically for bacteria evolution ----
;; unlike random mutationFunction, this steers mutations toward the body-genome
;; this models real molecular mimicry where pathogens evolve to look like host cells
;;
;; each base has two chances to change:
;; 1. mutationRate chance of DIRECTED mutation — copies the body-genome base at
;;    that position, directly nudging the bacterium toward mimicry
;; 2. mutationRate/2 chance of RANDOM mutation — keeps diversity in the population
;;    so not all bacteria collapse to the same genome immediately
;;
;; without this, mutation is a random walk with no gradient and the graph never moves
;; with this, bacteria visibly climb toward the body-genome each generation
to-report directedMutationFunction [cellGenome targetGenome mutationRate]
  let newGenome ""
  let genomeLength length cellGenome

  foreach n-values genomeLength [ i -> i ] [
    i ->
    let currentBase substring cellGenome i (i + 1)
    let targetBase  substring targetGenome i (i + 1)

    ifelse random-float 1 < mutationRate [
      ;; directed mutation — copy the body-genome base at this position
      ;; this is the engine that pushes bacteria toward mimicry each generation
      set newGenome word newGenome targetBase
    ] [
      ifelse random-float 1 < (mutationRate / 2) [
        ;; random mutation — maintains diversity so natural selection has
        ;; variation to work with and bacteria dont all become identical
        set newGenome word newGenome one-of remove currentBase bases
      ] [
        ;; keep original base unchanged
        set newGenome word newGenome currentBase
      ]
    ]
  ]
  report newGenome
end

;; ---- counts positional mismatches between two genome strings ----
;; used as a fast approximate similarity measure when strings are the same length
;; for strings of different lengths, also penalises the length difference
to-report genome-mismatch-count [g1 g2]
  if not is-string? g1 [ report 0 ]
  if not is-string? g2 [ report 0 ]
  if length g1 = 0 [ report 0 ]
  if length g2 = 0 [ report 0 ]

  let compare-length min (list (length g1) (length g2))
  let mismatch-count 0
  let i 0

  while [i < compare-length] [
    if substring g1 i (i + 1) != substring g2 i (i + 1) [
      set mismatch-count mismatch-count + 1
    ]
    set i (i + 1)
  ]

  ;; add penalty for any length difference between the two strings
  report mismatch-count + abs ((length g1) - (length g2))
end

