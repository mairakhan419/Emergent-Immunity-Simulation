;; ---- generates a random 16-character genome string ----
;; used at setup for all agent types before evolution begins
to-report randomGenomeFunction
  ;; How to use: let cellGenome randomGenomeFunction
  ;; goal: Generate a random 16-character sequence of 'AGTC'
  let seq ""
  repeat 16 [
    set seq word seq one-of bases
  ]
  report seq
end

;; ---- creates an offspring genome by crossing over two parent genomes ----
;; used by immune cell evolution (macrophages and neutrophils use sexual recombination)
to-report recombinationFunction [p1 p2]
  ;; How to use: call with two parent genome strings
  ;; a random crossover point k is chosen
  ;; offspring = first k chars of p1 + remaining chars of p2
  ;; this mixes traits from both fit parents to hopefully produce a better offspring
  ;; Probably a good idea to also run mutationFunction after this to add randomness
  ;; and prevent getting stuck at a local optimum instead of finding global optimum

  ;; making the cutoff point random
  let cutoff random (length p1)

  ;; split both parents at cutoff, combine, and return result
  report word
    (substring p1 0 cutoff)
    (substring p2 cutoff length p2)
end

;; ---- mutates a genome string at a given per-character rate ----
;; used by immune cells during evolution (random undirected mutation)
;; bacteria use directedMutationFunction instead for guided evolution toward body-genome
to-report mutationFunction [cellGenome mutationRate]
  ;; How to use: pass genome string and rate e.g. 0.05 for 5% chance per character
  ;; each character independently has mutationRate chance of being replaced
  ;; replacement is always a DIFFERENT base than the current one
  let newGenome ""
  let genomeLength length cellGenome

  ;; loop through each character in the genome
  foreach n-values genomeLength [ i -> i ] [
    i ->
    let base substring cellGenome i (i + 1) ;; get one character at position i
    ifelse random-float 1 < mutationRate [
      ;; mutate: replace with a randomly chosen different base
      set newGenome word newGenome one-of remove base bases
    ] [
      ;; keep original base unchanged
      set newGenome word newGenome base
    ]
  ]
  report newGenome
end

