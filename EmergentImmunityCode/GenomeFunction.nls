;; ---- converts edit distance into a 0-1 similarity score ----
;; 1.0 = identical genomes
;; 0.0 = completely different genomes
;;
;; this is the core of the immune recognition system:
;; immune cells compare a bacterium's genome to body-genome using this score
;; if similarity >= (lvenchisten-function / 100) the immune cell leaves it alone
;; if similarity <  (lvenchisten-function / 100) the immune cell attacks it
;;
;; high lvenchisten-function = immune cells only attack very foreign bacteria
;; low  lvenchisten-function = immune cells attack almost everything
to-report genome-similarity [g1 g2]
  if not is-string? g1 [ report 0 ]
  if not is-string? g2 [ report 0 ]
  if length g1 = 0 [ report 0 ]
  if length g2 = 0 [ report 0 ]
