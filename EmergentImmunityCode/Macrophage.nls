;; ---- helper: sets up a single new macrophage agent ----
to initialise-macrophage
  ;; build genome from slider values for A and G counts
  ;; remaining characters are randomly T or C (unused by macrophages)
  let num-a macrophage-sensitivity-a
  let num-g macrophage-eat-capacity-g
  let num-random max (list 0 (16 - num-a - num-g))

  let a-section      ifelse-value (num-a > 0)      [ reduce word n-values num-a      [i -> "A"] ] [ "" ]
  let g-section      ifelse-value (num-g > 0)      [ reduce word n-values num-g      [i -> "G"] ] [ "" ]
  let random-section ifelse-value (num-random > 0) [ reduce word n-values num-random [i -> one-of ["T" "C"]] ] [ "" ]
  set genome (word a-section g-section random-section)

  ;; count As in genome to set sensitivity
  set sensitivity length filter [c -> c = "A"] (n-values (length genome) [i -> substring genome i (i + 1)])

  ;; count Gs in genome to set max-eat capacity
  set max-eat length filter [c -> c = "G"] (n-values (length genome) [i -> substring genome i (i + 1)])

  ;; guard: macrophage must be able to eat at least 1 bacterium
  ;; without this, macrophages with G=0 die instantly on spawn
  if max-eat < 1 [ set max-eat 1 ]

  set eat-count 0
  set ticks-survived 0

  set shape "circle"
  set color violet
  set size 1

  ;; try to place on a healthy cell patch to start defending tissue immediately
  ;; fall back to any random patch if no healthy cells exist
  let start-patch one-of patches with [healthy?]
  ifelse start-patch != nobody [
    move-to start-patch
  ] [
    move-to one-of patches
  ]
end

