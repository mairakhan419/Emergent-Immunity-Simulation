;; ---- handles the immune recognition check and eating bacteria on current patch ----
;; this is the self/non-self discrimination logic:
;; the macrophage compares each bacterium's genome similarity to body-genome
;; against the lvenchisten-function threshold to decide whether to attack or ignore
to macrophage-eat [similarity-threshold]
  if any? bacteria-here [
    let target one-of bacteria-here

    ;; read the bacterium's current similarity-to-body score
    ;; this is updated every tick in bacteria-update-colour so it is always current
    let similarity [similarity-to-body] of target

    ifelse similarity < similarity-threshold [
      ;; similarity is BELOW threshold — bacterium looks foreign enough to attack
      ;; macrophage eats it and deposits p2 pheromone for neutrophils to follow
      ask target [ die ]
>>>>>>> Stashed changes
      set eat-count eat-count + 1
      set macrophages-pheromone macrophages-pheromone + 30
    ] [
      ;; similarity is AT OR ABOVE threshold — bacterium looks too similar to healthy tissue
      ;; macrophage mistakes it for a body cell and leaves it alone
      ;; this increments the bacterium's times-fooled fitness score
      ;; bacteria that consistently fool immune cells pass this genome to next generation
      ask target [ set times-fooled times-fooled + 1 ]
    ]
  ]

  ;; die of exhaustion once eat-count reaches max-eat
  if eat-count >= max-eat [ die ]
end