;; ---- decides where the macrophage moves each tick ----
to macrophage-move
  ;; threshold determines how faint a p1 signal this macrophage will react to
  ;; higher sensitivity (more As in genome) = lower threshold = responds to fainter signals
  ;; sensitivity ranges 0-16 so threshold ranges 32 (barely sensitive) to 0 (super sensitive)
  let threshold (16 - sensitivity) * 2

  ;; look at 8 surrounding patches and find the one with the strongest p1 distress signal
  let best-neighbor max-one-of neighbors [pheromone]

  ifelse [pheromone] of best-neighbor > threshold [
    move-to best-neighbor   ;; signal strong enough — move toward infection site
  ] [
    ;; no signal detected — wander randomly
    rt random 50 - 25  ;; turn random amount between -25 and +25 degrees
    fd 1               ;; move forward 1 step
  ]
end

