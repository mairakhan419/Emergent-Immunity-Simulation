>>>>>>> Stashed changes
  let random-section ifelse-value (num-random > 0) [ reduce word n-values num-random [i -> one-of ["A" "G"]] ] [ "" ]
  set genome (word c-section t-section random-section)

  ;; count Cs to set p2 sensitivity
  set sensitivity   length filter [c -> c = "C"] (n-values (length genome) [i -> substring genome i (i + 1)])

  ;; count Ts to set damage radius
  set damage-radius length filter [c -> c = "T"] (n-values (length genome) [i -> substring genome i (i + 1)])

  ;; guard: damage radius of at least 1 so neutrophil can always hit something
  ;; without this, neutrophils with T=0 can never kill any bacteria
  if damage-radius < 1 [ set damage-radius 1 ]

  set spit-count 0
  set max-spit 30   ;; neutrophil dies after 30 spit attacks — intentionally short lifespan

  set bacteria-killed 0
  set friendly-fire 0

  set shape "circle"
  set color blue
  set size 1

  ;; try to place near an existing macrophage pheromone trail
  ;; if no p2 signal exists yet, place on a random patch
  let start-patch one-of patches with [macrophages-pheromone > 0]
  ifelse start-patch != nobody [
    move-to start-patch
  ] [
    move-to one-of patches
  ]
end

