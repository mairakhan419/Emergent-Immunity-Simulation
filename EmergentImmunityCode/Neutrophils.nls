;; ---- fires a spit attack in a radius around the neutrophil ----
;; also performs immune recognition check same as macrophages:
;; bacteria whose genome is similar enough to body-genome fool the neutrophil too
to neutrophil-attack [similarity-threshold]
  ;; find all bacteria within spit radius
  let all-in-range bacteria in-radius damage-radius

  if any? all-in-range [
    ;; split into targetable (foreign genome) and fooling (mimicry genome)
    ;; targetable: similarity < threshold — looks foreign enough to attack
    ;; fooling: similarity >= threshold — looks too similar to healthy tissue
    let targetable-bacteria all-in-range with [similarity-to-body < similarity-threshold]
    let fooling-bacteria    all-in-range with [similarity-to-body >= similarity-threshold]

    ;; bacteria that fooled the neutrophil get a fitness bonus
    ;; this rewards mimicry even against second-wave immune response
    ask fooling-bacteria [ set times-fooled times-fooled + 1 ]

    if any? targetable-bacteria [
      ;; track how many bacteria are killed (fitness score for neutrophil)
      let kill-count count targetable-bacteria
      set bacteria-killed bacteria-killed + kill-count
      ask targetable-bacteria [ die ]

      ;; collateral damage: healthy cells in the blast radius also get eaten
      ;; this models real inflammatory tissue damage — neutrophils are aggressive
      ;; and not precise, which is why friendly-fire penalises their fitness score
      let damaged-cells patches in-radius damage-radius with [healthy?]
      set friendly-fire friendly-fire + count damaged-cells
      ask damaged-cells [ set eaten? true ]

      set spit-count spit-count + 1
    ]
  ]
