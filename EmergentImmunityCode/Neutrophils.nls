;; neutrophils are the second wave of the immune response
;; after macrophages eat bacteria, they leave a p2 pheromone trail
;; neutrophils follow the p2 trail and fire a spit attack that
;; damages all cells nearby — including healthy ones (collateral / friendly fire)
;; this models real inflammatory tissue damage during infection

;; neutrophil genome encoding:
;; C count -- sensitivity to p2 pheromone
;;            more C = lower detection threshold = follows fainter macrophage trails
;; T count -- damage radius for spit attack
;;            more T = larger area-of-effect attack
;; A and G are unused by neutrophils (filled randomly)

;; immune recognition:
;; like macrophages, neutrophils also check similarity-to-body before attacking
;; bacteria that have evolved strong mimicry (similarity >= threshold) fool
;; neutrophils too and get times-fooled incremented as a fitness reward

breed [neutrophils neutrophil]

neutrophils-own [
  genome
  sensitivity    ;; how faint a p2 signal will trigger movement — from C count
  damage-radius  ;; radius of spit attack in patches — from T count
  spit-count     ;; how many spit attacks this neutrophil has fired
  max-spit       ;; neutrophils die after 30 spits (fixed short lifespan)
  bacteria-killed  ;; total bacteria killed across all spit attacks (fitness score)
  friendly-fire    ;; total healthy cells damaged by spit attacks (fitness penalty)
]

;; ---- runs once when setup button is clicked ----
to setup-neutrophils
  create-neutrophils neutrophil-spawn-rate [
    initialise-neutrophil
  ]
end

;; ---- helper: sets up a single new neutrophil agent ----
to initialise-neutrophil
  ;; build genome from slider values for C and T counts
  ;; remaining characters randomly filled with A or G (unused by neutrophils)
  let num-c neutrophil-sensitivity-c
  let num-t neutrophil-damage-radius-t
