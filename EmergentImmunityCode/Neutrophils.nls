; ---- function for firing spit attacks ----
to neutrophil-attack
  let all-in-range bacteria in-radius damage-radius
  ;only target bacteria whose genome looks foreign from healthy cells 
  let targetable-bacteria all-in-range with [
    genome-similarity genome body-genome < (lvenchisten-function / 100)
  ]
  
  ;bacteria gets credit for fooling immune cell (fitness counter)
  let fooling-bacteria all-in-range with [
    genome-similarity genome body-genome >= (lvenchisten-function / 100)
  ]
  
  ask fooling-bacteria [set times-fooled times-fooled + 1]
  
  if any? targetable-bacteria [
    ;count how many bacteria going to get killed (fitness measure)
    let kill-count count targetable-bacteria
    set bacteria-killed bacteria-killed + kill-count
    
    ask targetable-bacteria [die]  ;kill all targeted bacteria in the radius 
    
    ;also mark all healthy cells as eaten within damage radius (tradeoff) 
    let damaged-cells patches in-radius damage-radius with [healthy?]
    set friendly-fire friendly-fire + count damaged-cells
    ask damaged-cells [set eaten? true] 
    
    ;count this as one spit 
    set spit-count spit-count + 1
  ]
  
  ;if this neutrophil used up its spit rounds, it dies off
  if spit-count >= max-spit [die]
end 

  










































